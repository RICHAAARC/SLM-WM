{
  "allowed_profile_variation_fields": [
    "profile_id",
    "scale_contract.protocol_profile",
    "scale_contract.target_fpr",
    "scale_contract.prompt_set",
    "scale_contract.prompt_file",
    "scale_contract.prompt_count",
    "scale_contract.sample_count",
    "scale_contract.split_counts",
    "scale_contract.minimum_negative_role_counts",
    "scale_contract.dataset_level_quality_minimum_count",
    "scale_contract.record_count_derivation"
  ],
  "method_role_contract": {
    "contract_schema": "dual_chain_method_role_contract_v1",
    "role_ids": [
      "full_dual_chain",
      "uniform_content_routing",
      "lf_only_content",
      "hf_tail_only_content",
      "content_chain_only",
      "geometry_recovery_without_embedded_sync"
    ]
  },
  "sample_role_contract": {
    "contract_schema": "dual_chain_sample_role_contract_v1",
    "role_ids": [
      "watermarked_positive",
      "clean_negative",
      "attacked_negative"
    ]
  },
  "formal_evaluation_schema_contract": {
    "schema_id": "dual_chain_formal_evaluation_success_failure_v1",
    "identity_fields": [
      "prompt_id",
      "randomization_repeat_id",
      "method_role",
      "sample_role",
      "key_relation",
      "attack_id",
      "decision_identity_digest"
    ],
    "union_fields": [
      "measurement_status",
      "failure_boundary",
      "failure_code",
      "measurement_identity_digest",
      "geometry_measurement",
      "evidence_positive"
    ]
  },
  "artifact_contract": [
    {
      "artifact_id": "randomization_detection_statistics_manifest",
      "file_names": [
        "prompt_cluster_detection_records.jsonl",
        "method_detection_operating_points.csv",
        "method_attack_detection_metrics.csv",
        "slm_wrong_key_detection_metric.csv",
        "per_attack_superiority_table.csv",
        "randomization_detection_statistics_summary.json",
        "randomization_detection_statistics_report.json",
        "manifest.local.json"
      ],
      "ready_field": "randomization_detection_statistics_ready",
      "writer_module": "paper_experiments.runners.randomization_detection_statistics"
    },
    {
      "artifact_id": "randomization_paired_superiority_manifest",
      "file_names": [
        "method_repeat_threshold_records.jsonl",
        "paired_outcomes.jsonl",
        "quality_matching_records.jsonl",
        "paired_superiority_table.csv",
        "paired_superiority_summary.json",
        "randomization_paired_superiority_report.json",
        "manifest.local.json"
      ],
      "ready_field": "randomization_paired_statistics_ready",
      "writer_module": "paper_experiments.runners.randomization_paired_superiority"
    },
    {
      "artifact_id": "randomization_dataset_quality_manifest",
      "file_names": [
        "fid_kid_metrics.csv",
        "quality_feature_membership.jsonl",
        "prompt_distributional_quality_records.jsonl",
        "attack_prompt_distributional_quality_records.jsonl",
        "randomization_dataset_quality_summary.json",
        "randomization_dataset_quality_report.json",
        "manifest.local.json"
      ],
      "ready_field": "randomization_dataset_quality_statistics_ready",
      "writer_module": "paper_experiments.runners.randomization_dataset_quality"
    },
    {
      "artifact_id": "randomization_ablation_necessity_manifest",
      "file_names": [
        "mechanism_necessity_statistics.csv",
        "mechanism_necessity_summary.json",
        "randomization_ablation_necessity_report.json",
        "manifest.local.json"
      ],
      "ready_field": "randomization_aggregate_statistics_ready",
      "writer_module": "paper_experiments.runners.randomization_ablation_necessity"
    }
  ],
  "command_dependency_edges": [
    {
      "consumer": "paper_experiments.runners.randomization_detection_statistics",
      "producer": "randomization_aggregate_package"
    },
    {
      "consumer": "paper_experiments.runners.randomization_paired_superiority",
      "producer": "randomization_aggregate_package"
    },
    {
      "consumer": "paper_experiments.runners.randomization_dataset_quality",
      "producer": "randomization_aggregate_package"
    },
    {
      "consumer": "paper_experiments.runners.randomization_ablation_necessity",
      "producer": "randomization_aggregate_package"
    },
    {
      "consumer": "paper_experiments.runners.single_model_parameter_sensitivity_diagnostic",
      "producer": "registered_single_repeat_evidence"
    },
    {
      "consumer": "scripts.paper_result_closure",
      "producer": "registered_randomization_statistics"
    },
    {
      "consumer": "scripts.write_paper_complete_result_package",
      "producer": "paper_result_closure_gate_report"
    }
  ],
  "gate_roles": [
    {
      "artifact_id": "randomization_detection_statistics_manifest",
      "claim_id": "fixed_fpr_detection",
      "gate_role": "fixed_fpr_negative_population_gate",
      "requirement_role": "required_claim"
    },
    {
      "artifact_id": "randomization_paired_superiority_manifest",
      "claim_id": "baseline_superiority",
      "gate_role": "paired_quality_matched_superiority_gate",
      "requirement_role": "required_claim"
    },
    {
      "artifact_id": "randomization_dataset_quality_manifest",
      "claim_id": "quality_preservation",
      "gate_role": "dataset_quality_measurement",
      "requirement_role": "required_claim"
    },
    {
      "artifact_id": "randomization_ablation_necessity_manifest",
      "claim_id": "mechanism_necessity",
      "gate_role": "mechanism_necessity_gate",
      "requirement_role": "required_claim"
    }
  ],
  "profile_ids": [
    "probe_paper",
    "pilot_paper",
    "full_paper"
  ],
  "registry_schema": "paper_profile_protocol_registry_v1",
  "diagnostic_artifact_contract": [
    {
      "artifact_id": "single_model_parameter_sensitivity_diagnostic_manifest",
      "file_names": [
        "parameter_sensitivity_diagnostic_records.jsonl",
        "parameter_sensitivity_diagnostic_summary.json",
        "manifest.local.json"
      ],
      "ready_field": "parameter_sensitivity_diagnostic_ready",
      "writer_module": "paper_experiments.runners.single_model_parameter_sensitivity_diagnostic"
    }
  ]
}
